# EMMA Municipal Distress Monitoring System — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# Document Storage
# ---------------------------------------------------------------------------

# Where raw PDFs are stored. Defaults to data/raw_documents/ inside the project.
# To use an external hard drive, set this to the drive's mount path:
#
#   macOS (drive named "EmmaArchive"):
#     EMMA_STORAGE_DIR=/Volumes/EmmaArchive/raw_documents
#
#   Linux / USB:
#     EMMA_STORAGE_DIR=/media/alex/EmmaArchive/raw_documents
#
#   Windows (if running under WSL):
#     EMMA_STORAGE_DIR=/mnt/e/EmmaArchive/raw_documents
#
# Leave commented to use the local default (data/raw_documents/).
# EMMA_STORAGE_DIR=/Volumes/EmmaArchive/raw_documents

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLAlchemy connection string.
# SQLite (default — good for development and single-machine use):
# EMMA_DATABASE_URL=sqlite:////absolute/path/to/emma.db
#
# PostgreSQL (for production or multi-user access):
# EMMA_DATABASE_URL=postgresql://user:password@localhost:5432/emma

# ---------------------------------------------------------------------------
# Claude API (required for Phase 4 — AI extraction)
# ---------------------------------------------------------------------------

# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Model used for full financial statement / event notice extraction.
# Default: claude-sonnet-4-6
# EMMA_EXTRACTION_MODEL=claude-sonnet-4-6

# Model used for cheap first-page document classification.
# Default: claude-haiku-4-5
# EMMA_CLASSIFICATION_MODEL=claude-haiku-4-5

# ---------------------------------------------------------------------------
# Scraper Rate Limits (adjust with care — EMMA is a public service)
# ---------------------------------------------------------------------------

# Seconds between discovery requests (JSON/HTML). Default: 1.0
# EMMA_DISCOVERY_DELAY=1.0

# Seconds between PDF download requests. Default: 2.5
# EMMA_DOWNLOAD_DELAY=2.5

# Maximum parallel download workers (hard max: 3). Default: 3
# EMMA_MAX_WORKERS=3
